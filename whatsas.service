[Unit]
Description=WhatSaS Flask API
After=network.target

[Service]
User=student
WorkingDirectory=/home/student/WhatSaS
EnvironmentFile=/home/student/WhatSaS/.env
ExecStart=/home/student/WhatSaS/venv/bin/gunicorn server.run:app \
    --bind 127.0.0.1:5000 \
    --workers 2 \
    --access-logfile - \
    --error-logfile -
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
